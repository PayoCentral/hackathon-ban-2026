<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/surfaceColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header row (Title and Status) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_club_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/tv_club_status"
                android:text="Club de Cine Debate"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Status Indicator (Chip Style) -->
            <TextView
                android:id="@+id/tv_club_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Activa"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_status_chip" />
        </RelativeLayout>

        <!-- Category/Schedule -->
        <TextView
            android:id="@+id/tv_club_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artes Audiovisuales • Miércoles 14:00 hrs"
            android:textColor="@color/colorPrimary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/tv_club_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Análisis y discusión de obras cinematográficas independientes y de culto. Abierto a toda la facultad..."
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="12dp" />

        <!-- Action / Indicator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="Ver Detalles →"
            android:textColor="@color/colorAccent"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
