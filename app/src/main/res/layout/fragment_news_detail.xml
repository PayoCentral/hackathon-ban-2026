<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    tools:context=".NewsDetailFragment">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Back Button and Image Container -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Rounded bottom corners image -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_news_detail"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/RoundedBottomCornersImageStyle"
                    app:srcCompat="@drawable/logo_facultad" />

                <!-- Floating back navigation button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_news_back"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:text="← Volver"
                    android:textColor="@color/white"
                    android:backgroundTint="#80031C36"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="16dp" />
            </RelativeLayout>

            <!-- Text Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- M3 Category Tag / Chip -->
                <TextView
                    android:id="@+id/tv_news_detail_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="CONVOCATORIA"
                    android:textColor="@color/colorSecondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"
                    android:background="@drawable/bg_status_chip"
                    android:backgroundTint="#FCE4EC" />

                <!-- Title (Serif) -->
                <TextView
                    android:id="@+id/tv_news_detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Título de la Noticia"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="6dp" />

                <!-- Date (Sans-serif) -->
                <TextView
                    android:id="@+id/tv_news_detail_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Publicado: 10 de Junio, 2026"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dividerColor"
                    android:layout_marginBottom="16dp" />

                <!-- Full Description (Serif) -->
                <TextView
                    android:id="@+id/tv_news_detail_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cuerpo de la noticia de prueba..."
                    android:textColor="@color/colorOnSurface"
                    android:textSize="15sp"
                    android:fontFamily="serif"
                    android:lineSpacingMultiplier="1.2"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
