<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    tools:context=".ClubDetailFragment">

    <!-- Header Fijo (Anclado al tope) -->
    <FrameLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_community"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <include
            android:id="@+id/customHeader"
            layout="@layout/view_common_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </FrameLayout>

    <!-- Scroll Central (Constreñido entre cabecera y botón) -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/detailScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toTopOf="@id/btnContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Back navigation button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Volver a la Lista"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginBottom="16dp"/>

            <!-- Category & Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                app:cardBackgroundColor="@color/surfaceColor">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_status"
                            android:textColor="@color/textSecondary"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tv_detail_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="Activa"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_status_chip" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_detail_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Artes Audiovisuales"
                        android:textColor="@color/colorPrimary"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_detail_schedule"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Horario: Miércoles de 14:00 a 16:00 hrs"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Event Image -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_detail_image"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:layout_marginBottom="24dp"
                app:shapeAppearanceOverlay="@style/RoundedImageStyle"
                android:visibility="gone" />

            <!-- Description Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descripción del Club"
                android:textColor="@color/colorOnSurface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_detail_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="El Club de Cine Debate es un espacio pensado para que los estudiantes de la Facultad de Artes analicen, dialoguen y exploren el lenguaje de directores de culto y del cine independiente. Cada semana proyectaremos una obra seleccionada y abriremos una mesa de diálogo en torno a sus componentes visuales, sonoros y narrativos. No se requiere experiencia previa en cine, solo pasión por contar y analizar historias."
                android:textColor="@color/textSecondary"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="24dp" />

            <!-- Additional details (location, requirements) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Información Adicional"
                android:textColor="@color/colorOnSurface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Lugar: Auditorio de Artes Plásticas\n• Cupo Máximo: 35 estudiantes\n• Requisitos: Ser alumno activo de la facultad y registrar su asistencia en cada sesión."
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Botón Fijo (Anclado al fondo) -->
    <LinearLayout
        android:id="@+id/btnContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_inscribirse"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_margin="16dp"
            android:text="@string/btn_inscribirse"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="24dp"
            app:backgroundTint="@color/colorSecondary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
