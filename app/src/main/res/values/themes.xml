<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.ARPAvisos" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/colorOnSurface</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/colorSecondaryContainer</item>
        
        <!-- Neutral / Background colors. -->
        <item name="android:windowBackground">@color/backgroundColor</item>
        
        <!-- Customize status bar for M3 light styling -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Circular avatar styling for ShapeableImageView -->
    <style name="CircleImageStyle">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Rounded bottom corners styling for ShapeableImageView -->
    <style name="RoundedBottomCornersImageStyle">
        <item name="cornerSizeBottomLeft">24dp</item>
        <item name="cornerSizeBottomRight">24dp</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">0dp</item>
    </style>

    <!-- General rounded corners styling for event/club images -->
    <style name="RoundedImageStyle">
        <item name="cornerSize">16dp</item>
    </style>
    <!-- Text appearance styles for BottomNavigationView animation -->
    <style name="NavInactiveText">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="NavActiveText">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>